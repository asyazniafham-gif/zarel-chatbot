# =============================================================================
# Zarel Sevan Chatbot — Environment Configuration Example
# Copy this file to backend.env and fill in your values
# =============================================================================

# ---------- DeepSeek API ----------
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ---------- Compute (CPU mode — AMD GPU, no CUDA) ----------
EMBEDDING_DEVICE=cpu
CROSS_ENCODER_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
INGEST_BATCH_SIZE=100

# ---------- HuggingFace Cache ----------
HF_HOME=/app/.hf_cache

# ---------- Retrieval ----------
RETRIEVAL_TOP_K=10
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ---------- Embedding ----------
LOCAL_EMBEDDING_MODEL=mesolitica/mistral-embedding-191m-8k-contrastive

# ---------- Redis Cache ----------
# Note: URL-encode special chars in password (/ → %2F, = → %3D)
REDIS_URL=redis://:your-redis-password@redis-container:6379
CACHE_TTL_SECONDS=600

# ---------- ChromaDB ----------
CHROMA_PERSIST_DIR=/app/chroma_db

# ---------- Paths ----------
LOCAL_KNOWLEDGE_PATH=/app/knowledge
LOCAL_DOCUMENTS_PATH=/app/documents
CSV_LOG_PATH=/app/logs/conversations.csv
FEEDBACK_CSV_PATH=/app/logs/feedback.csv
